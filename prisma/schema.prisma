generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth ───────────────────────────────────────────────────────────────────

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  firstName      String?
  lastName       String?
  avatarUrl      String?
  clerkId        String   @unique
  role           Role     @default(USER)
  stripeCustomerId String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  clients        Client[]
  projects       Project[]
  invoices       Invoice[]
  orders         Order[]
  styleAssessments StyleAssessment[]

  @@map("users")
}

enum Role {
  USER
  ADMIN
}

// ─── Clients ────────────────────────────────────────────────────────────────

model Client {
  id          String   @id @default(cuid())
  name        String
  email       String
  phone       String?
  company     String?
  notes       String?
  avatarUrl   String?
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  projects    Project[]
  invoices    Invoice[]

  @@map("clients")
}

// ─── Projects ───────────────────────────────────────────────────────────────

model Project {
  id          String        @id @default(cuid())
  name        String
  description String?
  status      ProjectStatus @default(DRAFT)
  budget      Decimal?      @db.Decimal(12, 2)
  startDate   DateTime?
  endDate     DateTime?
  coverImage  String?
  style       String?       // modern, traditional, transitional, etc.
  colorPalette String?      // JSON string of hex colors
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  clientId    String?
  client      Client?       @relation(fields: [clientId], references: [id], onDelete: SetNull)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  rooms           Room[]
  tasks           Task[]
  moodBoards      MoodBoard[]
  products        Product[]
  invoices        Invoice[]
  styleAssessments StyleAssessment[]
  orders          Order[]

  @@map("projects")
}

enum ProjectStatus {
  DRAFT
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
}

// ─── Rooms ──────────────────────────────────────────────────────────────────

model Room {
  id            String   @id @default(cuid())
  name          String
  description   String?
  roomType      String?  // living-room, bedroom, kitchen, etc.
  dimensions    String?  // e.g. "12x14 ft"
  notes         String?
  order         Int      @default(0)
  projectId     String
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tasks         Task[]
  products      Product[]
  moodBoards    MoodBoard[]

  @@map("rooms")
}

// ─── Tasks ──────────────────────────────────────────────────────────────────

model Task {
  id          String     @id @default(cuid())
  title       String
  description String?
  status      TaskStatus @default(TODO)
  priority    Priority   @default(MEDIUM)
  dueDate     DateTime?
  completedAt DateTime?
  order       Int        @default(0)
  projectId   String
  project     Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  roomId      String?
  room        Room?      @relation(fields: [roomId], references: [id], onDelete: SetNull)
  assigneeId  String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@map("tasks")
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  REVIEW
  COMPLETED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

// ─── Products & Sourcing ────────────────────────────────────────────────────

model Product {
  id            String   @id @default(cuid())
  name          String
  description   String?
  sku           String?
  category      String?  // furniture, lighting, textiles, decor, etc.
  brand         String?
  vendorName    String?
  retailPrice   Decimal? @db.Decimal(12, 2)
  tradePrice    Decimal? @db.Decimal(12, 2)
  currency      String   @default("USD")
  url           String?
  imageUrl      String?
  specifications String? // JSON for dimensions, materials, colors
  notes         String?
  status        ProductStatus @default(SPECIFIED)
  quantity      Int      @default(1)
  projectId     String
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  roomId        String?
  room          Room?    @relation(fields: [roomId], references: [id], onDelete: SetNull)
  orderId       String?
  order         Order?   @relation(fields: [orderId], references: [id], onDelete: SetNull)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("products")
}

enum ProductStatus {
  SPECIFIED
  QUOTED
  ORDERED
  SHIPPED
  DELIVERED
  RETURNED
}

// ─── Orders ─────────────────────────────────────────────────────────────────

model Order {
  id              String       @id @default(cuid())
  orderNumber     String       @unique
  status          OrderStatus  @default(PENDING)
  vendorName      String?
  vendorContact   String?
  subtotal        Decimal?     @db.Decimal(12, 2)
  tax             Decimal?     @db.Decimal(12, 2)
  shipping        Decimal?     @db.Decimal(12, 2)
  total           Decimal?     @db.Decimal(12, 2)
  currency        String       @default("USD")
  orderDate       DateTime?
  estimatedDelivery DateTime?
  trackingUrl     String?
  notes           String?
  userId          String
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId       String?
  project         Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  products        Product[]

  @@map("orders")
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

// ─── Mood Boards ────────────────────────────────────────────────────────────

model MoodBoard {
  id          String   @id @default(cuid())
  name        String
  description String?
  layout      String   @default("grid") // grid, freeform, canvas
  canvasData  String?  // JSON string of canvas elements/positions
  tags        String?  // JSON array of tags
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  roomId      String?
  room        Room?    @relation(fields: [roomId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items       MoodBoardItem[]

  @@map("mood_boards")
}

model MoodBoardItem {
  id          String   @id @default(cuid())
  type        String   // image, color, material, product, text
  content     String   // URL, hex color, text, product ID
  label       String?
  positionX   Float    @default(0)
  positionY   Float    @default(0)
  width       Float?
  height      Float?
  order       Int      @default(0)
  moodBoardId String
  moodBoard   MoodBoard @relation(fields: [moodBoardId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@map("mood_board_items")
}

// ─── Style Assessments ──────────────────────────────────────────────────────

model StyleAssessment {
  id          String   @id @default(cuid())
  name        String?  // client name or assessment name
  responses   String   @default("[]") // JSON array of question responses
  preferences String?  // JSON object of aggregated preferences
  styleProfile String? // JSON: modern, traditional, bohemian, etc. with scores
  colorPalette String? // JSON array of preferred colors
  notes       String?
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId   String?
  project     Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  clientName  String?
  clientEmail String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("style_assessments")
}

// ─── Invoices ───────────────────────────────────────────────────────────────

model Invoice {
  id            String        @id @default(cuid())
  invoiceNumber String        @unique
  status        InvoiceStatus @default(DRAFT)
  description   String?
  amount        Decimal       @db.Decimal(12, 2)
  taxRate       Decimal?      @db.Decimal(5, 2) @default(0)
  total         Decimal       @db.Decimal(12, 2)
  currency      String        @default("USD")
  dueDate       DateTime?
  paidAt        DateTime?
  stripeInvoiceId String?
  stripePaymentIntentId String?
  notes         String?
  userId        String
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId     String?
  project       Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)
  clientId      String?
  client        Client?       @relation(fields: [clientId], references: [id], onDelete: SetNull)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  lineItems     InvoiceLineItem[]

  @@map("invoices")
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
  REFUNDED
}

model InvoiceLineItem {
  id          String   @id @default(cuid())
  description String
  quantity    Int      @default(1)
  unitPrice   Decimal  @db.Decimal(12, 2)
  total       Decimal  @db.Decimal(12, 2)
  invoiceId   String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@map("invoice_line_items")
}